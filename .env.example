# 环境变量配置模板
# 复制此文件为 `.env` 并填写实际值

# Gate.io API配置
GATEIO_API_KEY=your_api_key_here
GATEIO_API_SECRET=your_api_secret_here

# 企微Webhook配置
WECOM_WEBHOOK_URL=your_webhook_url_here

# 交易配置
EXCHANGE_NAME=Gate.io
ACCOUNT_BALANCE=500
TRADING_PAIRS=BTC,ETH
LEVERAGE=200
DAILY_PROFIT_TARGET=200

# 监控配置
MONITOR_INTERVAL=60
PUSH_INTERVAL=300

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/monitor.log
